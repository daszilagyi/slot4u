# slot4u — Docker/WSL dev környezet env sablon.
# Másold .env-re a WSL repo gyökerében: cp .env.docker.example .env && (php) artisan key:generate
# A CLAUDE.md végleges döntései szerint: MariaDB, Redis, Reverb, Horizon, UTC idő.

APP_NAME=slot4u
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://slot4u.test

# i18n: a UI default magyar (lang/hu), en-re felkészítve
APP_LOCALE=hu
APP_FALLBACK_LOCALE=hu
APP_FAKER_LOCALE=hu_HU

# Idő: minden UTC-ben tárolva, tenant timezone csak megjelenítéskor
APP_TIMEZONE=UTC

# Multi-tenancy: a központi (tenant nélküli) domain — subdomainek: {tenant}.slot4u.test
APP_CENTRAL_DOMAIN=slot4u.test

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# --- Adatbázis: MariaDB konténer ---
DB_CONNECTION=mysql
DB_HOST=mariadb
DB_PORT=3306
DB_DATABASE=slot4u
DB_USERNAME=slot4u
DB_PASSWORD=secret
DB_ROOT_PASSWORD=root

# --- Cache / Session / Queue: Redis + Horizon ---
SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_DOMAIN=.slot4u.test
CACHE_STORE=redis
QUEUE_CONNECTION=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# --- Realtime: Reverb ---
BROADCAST_CONNECTION=reverb
REVERB_APP_ID=slot4u
REVERB_APP_KEY=slot4u-key
REVERB_APP_SECRET=slot4u-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

# --- Mail: dev-ben logba (M5-ben Mailpit/valós SMTP) ---
MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@slot4u.test"
MAIL_FROM_NAME="${APP_NAME}"

# A bind-mountolt fájljogokhoz (WSL): igazítsd a `id -u` / `id -g` értékeidhez
UID=1000
GID=1000

VITE_APP_NAME="${APP_NAME}"
